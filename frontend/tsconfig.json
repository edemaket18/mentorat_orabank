 {
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,

    "module": "Node16",
    "moduleResolution": "node16",
    "isolatedModules": true,
    "noEmit": true,

    "jsx": "react-jsx",

    "paths": {
      "*": ["./src/*"],
      "@/*": ["./src/*"],

      "@components/*": ["./src/components/*"],
      "@pages/*": ["./src/pages/*"],
      "@api/*": ["./src/api/*"],
      "@features/*": ["./src/features/*"],
      "@services/*": ["./src/services/*"],
      "@context/*": ["./src/context/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@assets/*": ["./src/assets/*"],
      "@routes/*": ["./src/routes/*"],
      "@styles/*": ["./src/styles/*"],
      "@types/*": ["./src/types/*"]
    },

    "types": [
      "node",
      "jest"
    ]
  },

  "include": [
    "src"
  ]
}
