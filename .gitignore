 # Dependencies
node_modules/
**/node_modules/

# Build files
build/
dist/
out/
coverage/

# Environment variables
# .env.development et .env.production (frontend) ne contiennent aucun secret
# (juste l'URL de l'API) : ils doivent être committés pour que l'équipe et
# les builds CI/mobile aient une config par défaut cohérente.
.env
.env.local
.env.*.local
!.env.example

# IDE specific files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# TypeScript cache
*.tsbuildinfo

# Frontend specific
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Backend specific
backend/dist/
backend/.env