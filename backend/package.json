{
  "name": "orabank-mentorat-platform-backend",
  "version": "1.0.0",
  "description": "Backend pour la plateforme de mentorat Orabank Togo",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed": "ts-node-dev --transpile-only src/scripts/seed.ts",
    "build": "tsc",
    "type": "module",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "swagger": "swagger-jsdoc -d swaggerDef.js -o swagger.json",
    "swagger:serve": "swagger-ui-express -p 3000 -f swagger.json",
    "swagger:generate": "swagger-jsdoc -d swaggerDef.js -o swagger.json",
    "swagger:serve-docs": "swagger-ui-express -p 3000 -f swagger.json",
    "test": "jest --runInBand --detectOpenHandles",
    "test:debug": "node --inspect-brk ./node_modules/.bin/jest --runInBand --detectOpenHandles",
    "test:debug:watch": "node --inspect-brk ./node_modules/.bin/jest --runInBand --detectOpenHandles --watch",
    "test:debug:coverage": "node --inspect-brk ./node_modules/.bin/jest --runInBand --detectOpenHandles --coverage",
    "test:unit": "jest --config jest.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:unit:watch": "jest --config jest.config.js --watch",
    "test:integration:watch": "jest --config jest.integration.config.js --watch",
    "test:unit:coverage": "jest --config jest.config.js --coverage",
    "test:integration:coverage": "jest --config jest.integration.config.js --coverage",
    "test:all": "jest --config jest.config.js && jest --config jest.integration.config.js",
    "test:all:watch": "jest --config jest.config.js --watch && jest --config jest.integration.config.js --watch",
    "test:all:coverage": "jest --config jest.config.js --coverage && jest --config jest.integration.config.js --coverage",
    "test:unit:debug": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js",
    "test:integration:debug": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js",
    "test:unit:debug:watch": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --watch",
    "test:integration:debug:watch": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --watch",
    "test:unit:debug:coverage": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage",
    "test:integration:debug:coverage": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage",
    "test:unit:debug:coverage:watch": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch",
    "test:integration:debug:coverage:watch": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch",
    "test:unit:debug:coverage:watch:all": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch",
    "test:integration:debug:coverage:watch:all": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch",
    "test:unit:debug:coverage:watch:all:coverage": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch",
    "test:integration:debug:coverage:watch:all:coverage": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch",
    "test:unit:debug:coverage:watch:all:coverage:all": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage && node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage",
    "test:integration:debug:coverage:watch:all:coverage:all": "node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage --watch && node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --coverage && node --inspect-brk ./node_modules/.bin/jest --config jest.integration.config.js --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "mentorat",
    "stage",
    "orabank",
    "plateforme"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.1",
    "mongoose": "^7.8.7",
    "multer": "^2.0.1",
    "mysql2": "^3.14.1",
    "nodemailer": "^7.0.3",
    "pdfkit": "^0.17.1",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.18",
    "@types/jest": "^29.5.14",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jspdf": "^1.3.3",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.11.19",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.14.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}